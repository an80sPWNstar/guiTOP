{
  "name": "guitop",
  "version": "0.2.3",
  "description": "guiTOP — a desktop GUI for NVIDIA GPU monitoring (local + multi-host over SSH)",
  "author": "an80sPWNstar <an80sPWNstar@users.noreply.github.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "build:win": "powershell.exe -Command \"Set-Location $PWD; npm run build\"",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "ssh2": "^1.16.0"
  },
  "build": {
    "appId": "com.guitop.app",
    "productName": "guiTOP",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "styles/**/*",
      "assets/**/*",
      "!renderer/skins/gauges.js"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}
